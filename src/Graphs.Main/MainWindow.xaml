<Window x:Class="Graphs.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="A* — Capitais Brasileiras (Cenário 2: Congestionamento)"
        Height="700" Width="1240"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- Painel esquerdo: controles -->
        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="Cenário" FontWeight="Bold" Margin="0,0,0,4"/>
            <RadioButton x:Name="cenario1Radio" Content="① Normal"
                         Checked="Cenario_Changed" Margin="0,0,0,2"/>
            <RadioButton x:Name="cenario2Radio" Content="② Congestionamento" IsChecked="True"
                         Checked="Cenario_Changed" Margin="0,0,0,12"/>

            <TextBlock Text="Rota" FontWeight="Bold" Margin="0,0,0,4"/>
            <Label Content="Origem:"/>
            <ComboBox x:Name="origemCombo" Margin="0,0,0,4"/>
            <Label Content="Destino:"/>
            <ComboBox x:Name="destinoCombo" Margin="0,0,0,12"/>

            <Button x:Name="rodarNormalButton" Content="Rodar Cenário Normal"
                    Click="RodarNormal_Click" Margin="0,0,0,12"/>

            <StackPanel x:Name="congestionamentoPanel">
                <TextBlock Text="Congestionamento" FontWeight="Bold" Margin="0,0,0,4"/>
                <Label Content="Fator (multiplica peso):"/>
                <TextBox x:Name="fatorInput" Text="4" Margin="0,0,0,4"/>
                <Button x:Name="congestionarButton" Content="Congestionar Rota Normal"
                        Click="Congestionar_Click" IsEnabled="False" Margin="0,0,0,12"/>
            </StackPanel>

            <Separator Margin="0,0,0,12"/>

            <CheckBox x:Name="mostrarArestasCheck" Content="Mostrar todas as arestas"
                      IsChecked="False" Checked="MostrarArestas_Changed"
                      Unchecked="MostrarArestas_Changed" Margin="0,0,0,12"/>

            <Button x:Name="nextStepButton" Content="▶ Próximo Passo"
                    Click="NextStep_Click" IsEnabled="False" Margin="0,0,0,5"/>
            <Button x:Name="runAllButton" Content="⏭ Executar Tudo"
                    Click="RunAll_Click" IsEnabled="False" Margin="0,0,0,5"/>
            <Button Content="↺ Reiniciar" Click="Reset_Click"/>

            <TextBlock x:Name="statusText" Margin="0,12,0,0" TextWrapping="Wrap"
                       Foreground="DarkRed" FontSize="11"/>

            <Border BorderBrush="LightGray" BorderThickness="1" Padding="6" Margin="0,12,0,0">
                <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="DimGray">
                    <Run FontWeight="Bold">F = G + H</Run><LineBreak/>
                    <Run FontWeight="Bold">G</Run><Run Text=" = km de estrada já percorridos da origem até o nó"/><LineBreak/>
                    <Run FontWeight="Bold">H</Run><Run Text=" = estimativa do restante: linha reta (IBGE) até o destino"/><LineBreak/>
                    <Run FontWeight="Bold">F</Run><Run Text=" = custo total estimado — A* fecha sempre o menor F"/>
                </TextBlock>
            </Border>
        </StackPanel>

        <!-- Centro: mapa das capitais -->
        <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Margin="5">
            <Canvas x:Name="graphCanvas" Background="White"
                    SizeChanged="GraphCanvas_SizeChanged"/>
        </Border>

        <!-- Painel direito: estado atual (Aberta/Fechada), etapas e comparação -->
        <Grid Grid.Column="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="90"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="90"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Lista Aberta (passo atual)" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" x:Name="listaAbertaBox" IsReadOnly="True" FontSize="11"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="2" Text="Lista Fechada (passo atual)" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox Grid.Row="3" x:Name="listaFechadaBox" IsReadOnly="True" FontSize="11"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="4" x:Name="etapasTitulo"
                       Text="Etapas (Abertos / Fechados)" FontWeight="Bold" Margin="0,0,0,4"/>
            <ListBox Grid.Row="5" x:Name="etapasList" FontSize="11"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="BorderBrush" Value="#EEE"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <TextBlock Grid.Row="6" x:Name="comparacaoText"
                       TextWrapping="Wrap" FontSize="12" Margin="0,8,0,0"/>
        </Grid>
    </Grid>
</Window>
