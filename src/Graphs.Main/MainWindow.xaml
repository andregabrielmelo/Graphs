<Window x:Class="Graphs.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Coloração de Grafos" Height="620" Width="960"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="210"/>
        </Grid.ColumnDefinitions>

        <!-- Painel esquerdo: gerenciamento do grafo -->
        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="Tipo de Grafo" FontWeight="Bold" Margin="0,0,0,4"/>
            <RadioButton x:Name="undirectedRadio" Content="Não-dirigido" IsChecked="True"
                         Checked="GraphDirection_Changed" Margin="0,0,0,2"/>
            <RadioButton x:Name="directedRadio"   Content="Dirigido"
                         Checked="GraphDirection_Changed" Margin="0,0,0,12"/>

            <TextBlock Text="Vértices" FontWeight="Bold" Margin="0,0,0,4"/>
            <Label Content="Nome:"/>
            <TextBox x:Name="vertexNameInput" Margin="0,0,0,4"/>
            <Button Content="Adicionar Vértice" Click="AddVertex_Click" Margin="0,0,0,3"/>
            <Button Content="Remover Vértice" Click="RemoveVertex_Click" Margin="0,0,0,16"/>

            <TextBlock Text="Arestas" FontWeight="Bold" Margin="0,0,0,4"/>
            <Label Content="De:"/>
            <TextBox x:Name="edgeFromInput" Margin="0,0,0,4"/>
            <Label Content="Para:"/>
            <TextBox x:Name="edgeToInput" Margin="0,0,0,4"/>
            <Button Content="Adicionar Aresta" Click="AddEdge_Click" Margin="0,0,0,3"/>
            <Button Content="Remover Aresta" Click="RemoveEdge_Click" Margin="0,0,0,16"/>

            <Separator Margin="0,0,0,16"/>

            <Button x:Name="nextStepButton" Content="▶ Próximo Passo" Click="NextStep_Click" Margin="0,0,0,5"/>
            <Button x:Name="runAllButton" Content="⏭ Executar Tudo" Click="RunAll_Click" Margin="0,0,0,5"/>
            <Button Content="↺ Reiniciar" Click="Reset_Click"/>

            <TextBlock x:Name="statusText" Margin="0,12,0,0" TextWrapping="Wrap"
                       Foreground="DarkRed" FontSize="11"/>
        </StackPanel>

        <!-- Centro: canvas do grafo -->
        <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Margin="5">
            <Canvas x:Name="graphCanvas" Background="White"
                    SizeChanged="GraphCanvas_SizeChanged"/>
        </Border>

        <!-- Painel direito: sequência de coloração -->
        <StackPanel Grid.Column="2" Margin="10">
            <TextBlock Text="Sequência de Coloração" FontWeight="Bold" Margin="0,0,0,8"/>
            <ListBox x:Name="coloringSequenceList" Height="540" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
