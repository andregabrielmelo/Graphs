<Window
  x:Class="Graphs.AStart.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="A* - Capitais Brasileiras"
  Height="720"
  Width="1300"
  Loaded="Window_Loaded"
>
  <Grid Margin="5">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="320" />
    </Grid.ColumnDefinitions>

    <!-- PAINEL ESQUERDO -->
    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="10">
        <TextBlock Text="Configuração" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />

        <TextBlock Text="Origem" />
        <ComboBox x:Name="originComboBox" Margin="0,5,0,10" />

        <TextBlock Text="Destino" />
        <ComboBox x:Name="destinationComboBox" Margin="0,5,0,10" />

        <Separator Margin="0,10" />

        <Button
          x:Name="nextStepButton"
          Content="▶ Próximo Passo"
          Height="32"
          Margin="0,0,0,5"
          Click="NextStep_Click"
        />

        <Button
          x:Name="runAllButton"
          Content="⏭ Executar Tudo"
          Height="32"
          Margin="0,0,0,5"
          Click="RunAll_Click"
        />

        <Button
          x:Name="resetButton"
          Content="↺ Reiniciar Busca"
          Height="32"
          Margin="0,0,0,15"
          Click="Reset_Click"
        />

        <Separator Margin="0,5" />

        <TextBlock Text="Congestionamento" FontWeight="Bold" Margin="0,10,0,10" />

        <Button
          x:Name="generateTrafficButton"
          Content="🚧 Gerar Congestionamento"
          Height="32"
          Margin="0,0,0,5"
          Click="GenerateTraffic_Click"
        />

        <Button
          x:Name="restoreWeightsButton"
          Content="✔ Restaurar Pesos"
          Height="32"
          Margin="0,0,0,15"
          Click="RestoreWeights_Click"
        />

        <Separator Margin="0,5" />

        <TextBlock Text="Resultado" FontWeight="Bold" Margin="0,10,0,10" />

        <TextBlock Text="Rota Normal" FontWeight="SemiBold" />

        <TextBox
          x:Name="normalRouteText"
          Height="90"
          Margin="0,5,0,10"
          IsReadOnly="True"
          TextWrapping="Wrap"
          VerticalScrollBarVisibility="Auto"
        />

        <TextBlock Text="Rota Congestionada" FontWeight="SemiBold" />

        <TextBox
          x:Name="trafficRouteText"
          Height="90"
          Margin="0,5,0,10"
          IsReadOnly="True"
          TextWrapping="Wrap"
          VerticalScrollBarVisibility="Auto"
        />

        <TextBlock
          x:Name="statusText"
          TextWrapping="Wrap"
          Foreground="DarkBlue"
          Margin="0,10,0,0"
        />
      </StackPanel>
    </ScrollViewer>

    <!-- CENTRO -->
    <Border Grid.Column="1" Margin="5" BorderBrush="LightGray" BorderThickness="1">
      <Canvas x:Name="graphCanvas" Background="White" SizeChanged="GraphCanvas_SizeChanged" />
    </Border>

    <!-- PAINEL DIREITO -->
    <Grid Grid.Column="2" Margin="10">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="*" />
        <RowDefinition Height="180" />
      </Grid.RowDefinitions>

      <GroupBox Header="Lista Aberta">
        <DockPanel>
          <TextBlock
            DockPanel.Dock="Top"
            FontFamily="Consolas"
            FontWeight="Bold"
            Margin="5"
            Text="Cidade             G      H      F"
          />

          <ListBox x:Name="openList" FontFamily="Consolas" />
        </DockPanel>
      </GroupBox>

      <GroupBox Header="Lista Fechada" Grid.Row="1" Margin="0,5,0,5">
        <ListBox x:Name="closedList" FontFamily="Consolas" />
      </GroupBox>

      <GroupBox Header="Comparação de Rotas" Grid.Row="2">
        <TextBox
          x:Name="comparisonText"
          IsReadOnly="True"
          TextWrapping="Wrap"
          VerticalScrollBarVisibility="Auto"
        />
      </GroupBox>
    </Grid>
  </Grid>
</Window>
